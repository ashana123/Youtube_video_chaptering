    {
        "start": 146.36,
        "end": 172.66,
        "text": "machine learning \u0915\u0947 \u0906\u0932\u094d\u0915\u0949\u0930\u094d\u0921\u093f\u0926\u092e\u094d\u0938 \u0907\u0902\u092a\u094d\u0932\u0947\u092e\u0947\u0902\u091f \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u092e\u0926\u0926 \u0915\u0930\u0924\u0940 \u0939\u0948\u0902, \u0907\u0938\u0915\u0947 \u092c\u093e\u0926 \u092e\u0947\u0902 \u0906\u092a \u0932\u094b\u0917\u094b",
