[
    {
        "start": 0.0,
        "end": 9.86,
        "text": "\u092a\u094d\u0930\u0936\u093e\u0907\u0928 \u0932\u0947\u0930\u0928\u093f\u0902\u0917 \u0915\u093e \u0915\u093e\u092b\u0940 \u092c\u0942\u092e \u0905\u091a\u0915\u0932 \u0939\u092e\u0947\u0902 \u0926\u0947\u0916\u0928\u0947 \u0915\u094b \u0928\u0939\u0940\u0902 \u0930\u0939\u093e \u0939\u0948\u0902, \u0905\u0930\u094d\u091f\u093f\u092b\u093f\u0936\u0932 \u0907\u0902\u0924\u0947\u0932\u093f\u091c\u093f\u0902\u0938 \u0928\u0939\u0940\u0902 \u0924\u0939\u0932 \u0915\u093e \u0932\u093f\u090f \u092a\u0930 \u091a\u093e\u0939\u093f\u0902\u0917 \u0935\u094b \u092a\u094d\u0930\u0949\u091f\u092c\u094d\u091f \u0938\u094b \u0932\u093e\u090f \u091a\u093e\u091f \u091c\u093f\u092a\u093f\u091f\u0940 \u092f\u093e \u092b\u093f\u0930 \u0906\u092a\u0915\u0947 \u0906\u092a\u0915\u0947 AI \u091f\u0942\u0932\u094d\u091c \u0915\u093f \u0906\u092a \u0926\u093f\u0932\u0940 \u092c\u0947\u0938\u0947\u091c \u092e\u0947\u0902 \u092f\u0942\u0938 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 9.86,
        "end": 15.9,
        "text": "\u0907\u0928 \u0938\u092c \u0915\u093e \u0906\u0926\u093e\u0930 \u0939\u0948\u0902 \u092e\u0936\u0940\u0928 \u0932\u0947\u0930\u0928\u093f\u0902\u0917 \u091c\u094b\u0915\u093f \u0906\u092a\u0915\u094b \u0938\u0940\u0915\u0928\u0940 \u092a\u0922\u093c\u0947\u0917\u0940 \u0905\u0917\u0930 \u0906\u092a \u0932\u0941\u0917 \u091c\u093e\u0928\u093e \u091a\u093e\u0924\u0947 \u0939\u0948\u0902 \u0905\u0930\u094d\u091f\u093f\u092b\u093f\u0936\u0932 \u0907\u0902\u0924\u0947\u0932\u093f\u091c\u093f\u0902\u0938 \u0915\u0947 \u0921\u094b\u092e\u0947\u0928 \u092e\u0947\u0902.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 15.9,
        "end": 24.08,
        "text": "\u0924\u094b \u0939\u093e\u0901 \u0938\u093e\u0925 \u091a\u094c\u092a\u0907\u0938 \u092e\u0947\u0902 \u0905\u0915\u0947\u0932\u0947 \u092e\u0936\u0940\u0928 \u0932\u0947\u0930\u0928\u093f\u0902\u0917 \u0915\u0940 \u092e\u093e\u0930\u0915\u0947\u091f 17% \u092c\u0922\u093c\u0940 \u0939\u0948\u0902 \u0914\u0930 \u0907\u0938 \u092a\u094d\u0930\u0949\u091f\u092c\u094d\u091f \u0915\u0947 \u0924\u094b \u0907\u0902\u0915\u0930\u0940\u0938 \u0906\u092a \u0930\u0947\u0921 \u0906\u092a 34% \u0907\u0928 \u0905\u092a\u0928\u0947 10 \u092f\u0939\u0930.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 24.16,
        "end": 29.0,
        "text": "\u0910\u0938\u093e \u092e\u093e\u0928\u093e \u091c\u093e \u0930\u0939\u093e \u0939\u0948 \u0915\u093f \u0907\u0902\u0921\u093f\u092f\u093e \u0907\u0938 \u0906\u092a \u092a\u0930 \u0935\u093f\u0915\u093e\u0932 \u092a\u0930 \u092c\u0916\u093e\u090f\u0902\u0917 \u092a\u093e\u0907\u0930 \u0939\u093e\u0901\u0938.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 29.0,
        "end": 33.02,
        "text": "\u092a\u094d\u0930\u0948\u0938\u093f\u0926\u0928 \u092c\u0941\u0930\u094d\u092e\u0941\u0930\u094b \u0928\u0947 \u092d\u0940 \u092c\u093e\u0924 \u0915\u0930\u0940 \u0925\u0940 \u092e\u0936\u0940\u0928 \u0932\u0947\u0930\u0928\u093f\u0902\u0917 \u090f\u0902\u0921 \u090f\u0902\u0921 \u090f\u0907 \u0905\u0907\u0921\u092c\u093e\u0938\u092e\u0947\u0902\u091f \u0915\u0940.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 33.12,
        "end": 37.38,
        "text": "\u0914\u0930 \u092a\u0948\u0938\u094b \u0915\u0940 \u0905\u0917\u0930 \u0939\u092e \u0932\u094b\u0917 \u092c\u093e\u0924 \u0915\u0930\u0947\u0902 \u0924\u094b \u092f\u0939\u093e\u0901 \u092a\u0930 \u0905\u0935\u0930\u093f\u0936 \u0938\u093e\u0932\u0930\u0940 \u0926\u0947\u0916\u0928\u0947 \u0915\u094b \u092e\u093f\u0932\u0924\u0940 \u0939\u0948\u0902.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 37.4,
        "end": 41.3,
        "text": "7-15 LPA \u0907\u0902\u0921\u093f\u092f\u093e \u092e\u0947\u0902 \u092e\u0936\u0940\u0928 \u0932\u0947\u0930\u0928\u093f\u0902\u0917 \u090f\u0902\u0921 \u090f\u0907 \u090f\u0902\u091c\u093f\u0928\u093f\u092f\u0930 \u0915\u0940.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 41.3,
        "end": 45.04,
        "text": "\u0905\u092a\u0928\u0947 50 LPA \u0915\u093f \u0906\u092a \u0906\u092a\u0915\u094b \u0928\u0939\u0940\u0902 \u0906\u092e\u0947\u0932 \u091c\u0940\u0928\u093f\u092f\u0930\u094d\u0938 \u0915\u094b \u091c\u093e \u0938\u0915\u0924\u0947 \u0939\u0948\u0902.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 45.04,
        "end": 49.06,
        "text": "\u092f\u0939\u093e\u0901 \u0906\u092a \u0932\u094b\u0917\u094b \u0928\u0947 \u0915\u094b\u0908 \u0928\u0939\u0940\u0902 \u090f\u0907 \u092e\u094b\u0921\u0932 \u092c\u0928\u093e \u0926\u093f\u092f\u093e, \u092f\u0939\u093e\u0901 \u090f\u0907 \u0938\u0947 \u0932\u093f\u090f\u091f \u0915\u094b\u0908 \u0928\u0939\u0940\u0902 \u091a\u0940\u0938 \u092c\u0928\u093e \u0926\u093f\u092f\u093e,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 49.08,
        "end": 52.56,
        "text": "\u090f\u0907 \u0924\u094b \u092f\u0942\u0938 \u0915\u0930 \u0915\u0947 \u0924\u0942\u0932 \u092c\u0928\u093e \u0926\u093f\u092f\u093e, \u0906\u092a \u0915\u094d\u092f\u093e \u092c\u093f\u0938\u094d\u0927\u0938 \u0915\u093e \u0930\u0939\u0947 \u0939\u0948\u0902.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 52.56,
        "end": 76.36,
        "text": "\u0909\u0928\u094d\u0939\u0941\u0917 \u0906\u0907\u0938\u094d\u0930\u0942\u092e\u094d\u092e\u093f bumps do EIP \u0939\u0948 Muslim",
        "pause_after": false,
