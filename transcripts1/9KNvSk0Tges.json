    {
        "start": 161.72,
        "end": 164.0,
        "text": "\u0936\u093e\u0921\u093c\u0947 \u092c\u093e\u0930\u093e \u0939\u093e\u091c\u093e\u0930 \u0915\u0940 \u091b\u0942\u091f \u092e\u093f\u0932 \u091c\u093e\u090f\u0917\u0940.",
        "pause_after": false,
