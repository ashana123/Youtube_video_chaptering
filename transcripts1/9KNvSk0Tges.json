[
    {
        "start": 0.0,
        "end": 4.3,
        "text": "\u0924\u094b \u092b\u093c\u093f\u0928\u093e\u0907\u0928\u094d\u0938 \u092e\u093f\u0928\u093f\u0938\u094d\u0924\u0930 \u092a\u093f\u092f\u0942\u0936 \u0917\u094c\u092f\u0932 \u0928\u0947 \u0907\u0938 \u0938\u093e\u0932 \u0915\u093e \u0907\u0902\u091f\u0930\u093f\u092e \u092c\u091c\u093c\u0947\u091f \u0905\u0928\u093e\u0909\u0928\u0938 \u0915\u0930 \u0926\u093f\u092f\u093e \u0939\u0948",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 4.3,
        "end": 8.4,
        "text": "\u0914\u0930 \u0909\u0938\u092e\u0947\u0902 \u0907\u0928\u0915\u092e \u0924\u0948\u0915\u094d\u0938 \u0938\u0947 \u0930\u0947\u0932\u0947\u091f\u0947\u0921 \u0906\u092a \u0938\u092d\u0940 \u0932\u094b\u0917\u094b \u0915\u0947 \u0932\u093f\u090f \u090f\u0915 \u0917\u0942\u0921 \u0928\u0942\u0938 \u0939\u0948",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 8.4,
        "end": 12.94,
        "text": "\u090f\u0915 \u0910\u0938\u0940 \u0928\u0942\u0938 \u091c\u093f\u0938\u0915\u094b \u0905\u0928\u093e\u0909\u0928\u0938 \u0915\u0930\u0924\u0947 \u0939\u0940 \u092a\u093e\u0932\u093f\u092e\u0947\u0921 \u092e\u0947\u0902 \u0916\u0942\u092c \u0938\u093e\u0930\u0940 \u0924\u093e\u0932\u093f\u092f\u093e\u0902 \u092c\u091c\u0940",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 12.94,
        "end": 16.1,
        "text": "\u0914\u0930 \u0909\u0938 \u0938\u0947 \u0921\u092c\u0932 \u0915\u0902\u092b\u0949\u091c\u093c\u0928 \u092d\u0940 \u092a\u0948\u0926\u093e \u0939\u094b \u0917\u092f\u093e",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 16.1,
        "end": 19.0,
        "text": "5 \u0932\u093e\u0915 \u0924\u0915 \u0915\u0940 \u0907\u0902\u0915\u092e \u092a\u0947 \u0924\u0948\u0915\u094d\u0938 \u0939\u0940 \u0928\u0939\u0940\u0902 \u092a\u0921\u093c\u0947\u0917\u093e",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 19.0,
        "end": 22.86,
        "text": "\u0910\u0938\u093e \u090f\u0915 \u0915\u0902\u092b\u0949\u091c\u093c\u0928 \u0932\u094b\u0917\u094b \u0915\u0947 \u092e\u0928\u094d\u092e\u0947\u0902 \u0915\u094d\u0930\u093f\u092f\u0947\u091f \u0939\u094b \u091a\u0941\u0915\u093e \u0939\u0948",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 22.86,
        "end": 25.8,
        "text": "\u0906\u091c \u0907\u0938 \u0935\u093f\u0921\u093f\u092f\u094b \u092e\u0947\u0902 \u0909\u0938\u0940 \u0915\u0902\u092b\u0949\u091c\u093c\u0928 \u0915\u094b \u0926\u0942\u0930 \u0915\u0930\u0947\u0902\u0917\u0947",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 25.8,
        "end": 32.36,
        "text": "\u0914\u0930 \u0906\u092a\u0915\u094b \u092f\u0947 \u092d\u0940 \u092c\u0924\u093e\u090f\u0902\u0917\u0947 \u0915\u093f 5 \u0932\u093e\u0915 \u0928\u0939\u0940\u0902 10 \u0932\u093e\u0915 \u0924\u0915 \u0915\u0940 \u0907\u0902\u0915\u092e \u092a\u0930 \u092d\u0940 \u0906\u092a\u0915\u094b \u0915\u094b\u0908 \u091f\u0948\u0915\u094d\u0938 \u0928\u0939\u0940\u0902 \u092c\u0930\u0928\u093e \u092a\u0921\u093c\u0947\u0917\u093e",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 32.36,
        "end": 36.2,
        "text": "\u0905\u0917\u0930 \u0906\u092a \u0907\u0938 \u0935\u093f\u0921\u093f\u092f\u094b \u092e\u0947\u0902 \u092c\u0924\u093e\u090f \u0917\u0908 \u0907\u0902\u092b\u0949\u091c\u093c\u0928 \u0915\u094b \u0927\u094d\u092f\u093e\u0928 \u0938\u0947 \u0926\u0947\u0916\u0947\u0902\u0917\u0947",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 36.2,
        "end": 38.84,
        "text": "\u092e\u0947\u0930\u093e \u0928\u093e\u092e \u0939\u0948 \u092e\u0902\u0926\u0940\u092b \u0906\u092a \u0926\u0947\u0916 \u0930\u0939\u0947 \u0939\u0948 \u0932\u0947\u092c\u0930 \u0932\u094b \u0907\u0921\u0935\u093e\u0907\u091c\u0930",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 38.84,
        "end": 45.06,
        "text": "\u0914\u0930 \u0939\u092e\u093e\u0930\u0947 \u091a\u0948\u0928\u0932 \u0915\u094b \u0938\u092c\u094d\u0938\u094d\u091f\u094d\u0930\u093e\u0907\u092c \u0915\u0930\u0915\u0947 \u092c\u0947\u0932\u093e \u0907\u0915\u0928 \u0926\u092c\u093e\u0928\u0947 \u092e\u0947\u0902 \u0906\u092a\u0915\u093e \u092c\u0939\u0941\u0924 \u092b\u093e\u0907\u0921\u093e \u0939\u0948 \u0915\u094d\u092f\u0942\u0915\u093f \u0910\u0938\u0947 \u0907\u092a\u092a\u0949\u091f\u0928\u094d\u091f \u0935\u093f\u0921\u093f\u092f\u094b\u0902 \u0938\u0947 \u0939\u092e \u092b\u094d\u0930\u0940\u0915\u0949\u0928\u094d\u091f\u0932\u0940 \u0921\u093e\u0932\u0924\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 59.42000000000001,
        "end": 63.48,
        "text": "\u0924\u094b \u0938\u092c\u0938\u0947 \u092e\u0947\u0932\u0947 \u092e\u0948\u0902 \u0906\u092a\u0915\u094b \u0907\u0928\u0915\u092e \u091f\u0948\u0915\u094d\u0938 \u0915\u0947 \u0938\u094d\u0932\u093e\u092c \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u092c\u0924\u093e \u0926\u0947\u0924\u093e \u0939\u0942\u0902",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 63.48,
        "end": 70.0,
        "text": "\u0907\u0902\u0921\u093f\u0935\u093f\u091c\u0949\u0932 \u0938\u0947 \u091c\u094b \u0932\u094b\u0917 60 \u0938\u093e\u0932 \u0938\u0947 \u0915\u092e \u0939\u0948\u0902 \u0905\u0917\u0930 \u0909\u0928\u0915\u0940 \u0907\u0928\u0915\u092e \u0926\u094d\u092f\u093e\u0907\u0932\u093e\u0915 \u0930\u0942\u092a\u0947 \u0924\u0915 \u0939\u0948 \u0924\u094b \u0909\u0928\u0915\u094b \u0915\u094b\u0908 \u091f\u0948\u0915\u094d\u0938 \u0928\u0939\u0940\u0902 \u0926\u0947\u0928\u093e \u0939\u094b\u0924\u093e",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 70.0,
        "end": 79.1,
        "text": "\u0907\u0928\u0915\u092e 2.5 to 5 lakh \u0915\u0947 \u090a\u0902\u0915\u092e \u0924\u094b \u092a\u094b\u0930\u0926\u5e94\u093f\u090f\u0902 to 5% \u0915\u093e \u0909\u0938\u0915 Presents Tax \u092a\u0947 \u0905\u092a\u0928\u093e \u0432\u0438\u30fc\u3093 \u092f\u0947 Nahe \u0905\u092a\u0928\u0947 \u0905\u0930\u094d\u0939 delays suspension",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 79.1,
        "end": 83.56,
        "text": "\u0914\u0930 \u0909\u0928\u0928\u0947 \u092d\u093e\u0930\u094d\u0923 \u0915\u0947 \u0932\u093f\u090f \u090e\u0902\u0915\u092e \u0930\u0939\u093e \u0939\u0948 \u0625\u0940\u0902\uc0ac\u307e\u305b\u3093",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 83.56,
        "end": 87.42,
        "text": "\u0914\u0930 \u0905\u092c \u0915\u0941\u091b \u0924\u0948\u092a \u0915\u0947 \u0938\u0947\u0938 \u092d\u0940 \u0932\u0915\u0924\u0947 \u0939\u0948\u0902 \u0909\u0938 \u091f\u0948\u0915\u0938 \u092a\u0947 \u0924\u094b \u0915\u093e\u092b\u0940 \u0932\u094c\u0917\u094b\u0902 \u0915\u0947 \u092e\u0928",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 87.42,
        "end": 91.72,
        "text": "\u0915\u094b \u0907\u0938\u0915\u0941\u092a \u0936\u093e\u0928\u094d\u0915 \u0915\u0940 \u0915\u094c\u0928 \u0917\u094c\u0923 \u0939\u094b\u0930\u093e \u0939\u0948 \u0915\u0932 \u0938\u0947 \u0915\u093f \u0905\u092c \u091c\u094b \u091f\u0948\u0915\u0938 \u0938\u094d\u0932\u093e\u092a \u0926\u094d\u0939\u093e\u0908 \u0932\u093e\u0917",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 91.72,
        "end": 95.8,
        "text": "\u0915\u0940 \u0925\u0940 \u0909\u0938\u0915\u094b \u092c\u0922\u093c\u093e\u0915\u0930 \u0915\u093f 5 \u0932\u093e\u0917 \u0915\u0930 \u0926\u093f\u092f\u093e \u0918\u0906 \u0939\u0948 \u0910\u0938\u093e \u092c\u0940 \u0932\u0947\u0915\u0942\u0932 \u0928\u0939\u0940\u0902 \u0939\u0948",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 95.8,
        "end": 100.18,
        "text": "5 lakh \u0924\u0915 \u0915\u0940 \u0907\u0928\u0915\u092e \u092a\u0930 \u091c\u0940\u0930\u094b \u091f\u0948\u0915\u094d\u0938 \u0939\u094b\u0924\u093e \u0939\u0948, \u092f\u0947 \u092c\u093e\u0926 \u092c\u093f\u0932\u0915\u0941\u0932 \u0917\u0932\u0924 \u0939\u0948.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 100.7,
        "end": 105.62,
        "text": "\u0939\u093e\u0909\u0935\u0947\u0935\u0930, \u092f\u0947 5 lakh \u0915\u0940 \u0907\u0928\u0915\u092e \u092a\u0930 \u091c\u0940\u0930\u094b \u091f\u0948\u0915\u094d\u0938 \u092b\u093f\u0930 \u092d\u0940 \u0915\u093e\u0932\u094d\u0915\u0942\u0932\u0947\u091f \u0939\u094b \u091c\u093e\u0924\u093e \u0939\u0948.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 105.76,
        "end": 111.18,
        "text": "\u0907\u0928\u0915\u092e \u092a\u0930 10 lakh \u0915\u0940 \u0907\u0928\u0915\u092e \u092a\u0930 \u0906\u092a \u0905\u092a\u0928\u093e \u091f\u0948\u0915\u094d\u0938 \u092a\u0942\u0930\u093e \u092a\u0942\u0930\u093e \u092c\u091a\u093e \u0938\u0915\u0924\u0947 \u0939\u0948\u0902, \u0906\u092a\u0915\u094b \u0915\u0941\u091b \u0928\u0939\u0940\u0902 \u092a\u0947 \u0915\u0930\u0928\u093e.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 111.18,
        "end": 114.5,
        "text": "\u0905\u092c \u0935\u094b \u0915\u0948\u0938\u0947 \u0938\u092e\u092d\u0935 \u0939\u0948, \u0909\u0938 \u092c\u093e\u0926 \u092a\u0947 \u0917\u094c\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0925\u094b\u0921\u093c\u093e \u0938\u093e.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 114.58,
        "end": 120.86,
        "text": "\u0924\u094b \u091c\u094b \u092e\u0947\u0902 \u092c\u0926\u0932\u093e\u0935 \u0906\u092f\u093e \u0939\u0948, \u0935\u094b \u0907\u0928\u0915\u092e \u0924\u0948\u0915\u094d\u0938 \u0915\u0947 \u0938\u0947\u0915\u094d\u0937\u0928 87A \u092e\u0947\u0902 \u0906\u092f\u093e \u0939\u0948, \u091c\u093f\u0938\u092e\u0947\u0902 \u092a\u0939\u0932\u0947 \u0932\u093f\u0916\u093e \u0925\u093e,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 121.1,
        "end": 125.9,
        "text": "\u0915\u093f \u091c\u093f\u0938\u0915\u0940 \u092d\u0940 \u0907\u0928\u0915\u092e 3 lakh \u0930\u0942\u092a\u0947 \u0924\u0915 \u0939\u0948, \u0909\u0938\u0915\u0947 25 \u0930\u0942\u092a\u0947 \u0915\u0940 \u091f\u0948\u0915\u094d\u0938 \u092e\u0947\u0902 \u091a\u0942\u091f \u092e\u0947\u0902 \u0932\u0947\u0917\u0940.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 125.9,
        "end": 131.02,
        "text": "\u092e\u0938\u0947 \u0915\u0940 \u092c\u093e\u0924 \u092f\u0939 \u0939\u0948, \u0915\u093f 3 lakh \u092a\u0930 \u0907\u0928\u0915\u092e \u091c\u092c \u0939\u094b\u0924\u0940 \u0925\u0940, \u0924\u094b \u091f\u0948\u0915\u094d\u0938 \u0939\u0940 25 \u0930\u0942\u092a\u0947 \u092c\u0928\u0924\u093e \u0925\u093e,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 131.12,
        "end": 133.42,
        "text": "\u0914\u0930 \u091a\u0942\u091f \u092d\u0940 25 \u0930\u0942\u092a\u0947 \u0915\u0940 \u092e\u093f\u0932 \u091c\u093e\u0924\u0940 \u0925\u0940.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 133.54,
        "end": 138.04,
        "text": "\u0907\u0938\u0915\u093e \u092e\u0924\u0932\u092c, \u0924\u0948\u0915\u094d\u0938 \u092a\u0947 \u0928\u0939\u0940\u0902 \u0915\u0930\u0928\u093e \u092a\u0930\u0924\u093e \u0925\u093e \u0909\u0928 \u0932\u094b\u0917\u094b\u0902 \u0915\u094b \u091c\u093f\u0928\u0915\u0940 \u0907\u0928\u0915\u092e 3 lakh \u0930\u0942\u092a\u0947 \u0924\u0915 \u0939\u0948.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 138.04,
        "end": 145.12,
        "text": "\u0907\u0938 \u0938\u0947\u0915\u094d\u0937\u0928 87A \u0915\u094b \u092c\u0926\u0932 \u0915\u0947 \u0907\u0938\u0915\u0940 \u0930\u093f\u0935\u0947\u091f \u092a\u091a\u093f\u0937 \u0938\u094b \u0938\u0947 \u092c\u0922\u093c\u093e \u0915\u0930 \u0930\u0939\u093e \u0939\u0948,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 145.52,
        "end": 148.64,
        "text": "\u0914\u0930 \u0907\u0928\u0915\u092e \u0915\u0940 \u0932\u093f\u092e\u093f\u091f 3 lakh \u0938\u0947 \u092c\u0922\u093c\u093e \u0915\u0930 \u0930\u0939\u093e \u0939\u0948.",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 149.18,
        "end": 153.38,
        "text": "\u092f\u093e\u0928\u0940, \u0905\u0917\u0930 \u0906\u092a\u0915\u0940 \u0907\u0928\u0915\u092e 5 lakh \u0924\u0915 \u0939\u0948, \u0914\u0930 \u0907\u0928\u0915\u092e \u0938\u0947 \u092e\u0947\u0902\u093e \u092e\u0924\u0932\u092c \u0939\u0948,",
        "pause_after": false,
