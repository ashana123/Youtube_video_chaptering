    },
    {
        "start": 153.48,
        "end": 156.36,
        "text": "\u0924\u0948\u0915\u094d\u0938\u093f\u092c\u0932 \u0907\u0928\u0915\u092e, \u091c\u093f\u0938 \u0907\u0928\u0915\u092e \u092a\u0930 \u091f\u0948\u0915\u094d\u0938 \u0932\u0917\u0928\u093e \u091a\u093e\u0939\u0940 \u0939\u0948,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 156.36,
