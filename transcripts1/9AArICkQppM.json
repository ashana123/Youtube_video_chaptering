        "text": "\u092d\u0941\u0930\u092e \u0938\u0940\u091b\u0947 \u0936 \u0915\u094c\u0908-\u091f\u0941\u092e\u094d\u0142am\u093e\u0930\u094d\u0924\u093f \u0915\u0940 \u092c\u0948\u094b \u0936\u093e\u0935\u0930\u094d\u092e\u093e\u0908\u0932, \u0935\u093f\u0937\u094d\u0930\u094d\u092e\u0949\u0928\u094d\u0924\u094d\u092e\u093e\u0903 this draft,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 938.14,
        "end": 958.1,
        "text": "\u0925\u0932\u0941osited 4II \u092a\u094d\u0930\u0947\u0923\u094d\u092e\u0932\u093e\u0907\u0917\u0947 \u0926\u0947 \u0930\u0939\u0947 \u0939\u0948\u0902 \u0935\u0949\u0928\u0939\u093e\u0926\u094d\u092f\u0947 \u0932\u093f\u0916\u093e Seni is a local public producer,",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 958.1,
        "end": 960.1,
        "text": "\u0915\u093f \u0909\u0938\u0947 \u092c\u0941\u0932\u093e\u092f\u093e \u0917\u092f\u093e \u0939\u0948\u0964",
        "pause_after": false,
        "tonal_change": false
    },
    {
        "start": 969.6999999999999,
        "end": 972.18,
        "text": "\u0914\u0930 \u0909\u0938\u0947 \u091a\u0941\u0928\u093e\u0928\u093e \u0917\u092f\u093e \u0939\u094b\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 998.0400000000001,
        "end": 1015.98,
        "text": "\u0906\u091c \u0932\u0947\u0935\u093e\u091c \u092a\u0930 \u0932\u0947\u0935\u093e\u091c \u0928\u0939\u0940\u0902 \u090f\u0915\u0947 \u0932\u0947\u0935\u093e\u091c \u092a\u0930 \u0932\u0947\u0935\u093e\u091c \u092a\u0930 \u0932\u0947.",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1018.68,
        "end": 1024.6,
        "text": "\u0935\u094b \u0924\u094b \u092c\u094d\u0932\u093e \u0939\u0940 \u0930\u0939\u093e \u0939\u0948\u0902 \u0909\u0938\u0928 \u0924\u0941\u092e\u0938\u0947 \u0928\u0939\u0940\u0902 \u0915\u0939\u093e \u090f\u0902 \u0924\u0941\u092e \u092c\u0947\u0939\u094b\u0936 \u0930\u0939\u0942, \u0924\u0941\u092e \u092c\u0947\u0939\u094b\u0936 \u0939\u094b",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1028.1000000000001,
        "end": 1030.6,
        "text": "\u0915\u094d\u092f\u094b\u0915\u093f \u0924\u0941\u092e\u093e\u0930\u093e \u0906\u0939\u093e\u0930 \u092c\u0947\u0939\u0942\u0937\u0940 \u0915\u093e \u0939\u0948\u0902",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1038.64,
        "end": 1041.6,
        "text": "\u0915\u094d\u092f\u094b\u0915\u093f \u091c\u093f\u0938 \u0939\u0935\u093e \u092e\u0947\u0902 \u0924\u0941\u092e \u0938\u093e\u0938 \u0932\u0947\u0924\u0947 \u0939\u094b \u0935\u094b \u092c\u0947\u0939\u0942\u0937\u0940 \u0915\u0940 \u0939\u0948\u0902",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1045.74,
        "end": 1050.86,
        "text": "\u091c\u094b \u0916\u093e\u0928\u093e \u0924\u0941\u092e \u0916\u093e\u0930\u0947 \u0939\u094b, \u091c\u094b \u092a\u093e\u0928\u0940 \u0924\u0941\u092e \u092a\u0940 \u0930\u0939\u0947 \u0939\u094b, \u0909\u0938 \u092e\u0947\u0902 \u0928\u0936\u093e \u0939\u0948\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1053.02,
        "end": 1059.86,
        "text": "\u091c\u093f\u0928\u0915\u0947 \u0936\u092c\u094d\u0927 \u0924\u0941\u092e\u0939\u093e\u0930\u0947 \u0915\u093e\u0928\u093e\u0913\u0902 \u092e\u0947\u0902 \u092a\u0921\u093c\u0924\u0947 \u0939\u0948\u0902, \u0909\u0928 \u092e\u0947\u0902 \u0928\u0936\u093e \u0939\u0948\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1078.5800000000002,
        "end": 1099.28,
        "text": "\u0928\u0936\u0947 \u0915\u0947 \u0938\u093e\u0925 \u0939\u0940 \u0909\u0920 \u092c\u0948\u091f \u0930\u0939\u0947 \u0939\u094b, \u0914\u0930 \u0915\u094b\u0908 \u092e\u091c\u092c\u0942\u0930\u0940 \u0928\u0939\u0940\u0902 \u0939\u0948, \u092a\u0930\u092e\u093e\u0924\u094d\u092e\u093e \u0915\u093e \u092b\u0930\u092e\u093e\u0928 \u0928\u0939\u0940\u0902 \u0939\u0948, \u0924\u0941\u092e\u0939\u093e\u0930\u093e \u0905\u092a\u0928\u093e \u091a\u0941\u0928\u093e\u0913 \u0939\u0948 \u092f\u0947\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1104.1,
        "end": 1111.28,
        "text": "\u0907\u0938 \u0938\u0947 \u092a\u0939\u0932\u0947 \u0915\u093f \u0924\u0941\u092e \u092f\u0947 \u092a\u0942\u091b\u094b \u0915\u093f \u092a\u0930\u092e\u093e\u0924\u094d\u092e\u093e \u092e\u0941\u091d\u0947 \u0915\u094d\u092f\u094b\u0902 \u0928\u0939\u0940\u0902 \u091a\u0941\u0928\u0924\u093e, \u0905\u092a\u0928\u0947 \u0906\u092a \u0938\u0947 \u092a\u0942\u091b\u094b \u0915\u093f \u0915\u094d\u092f\u093e \u0924\u0941\u092e\u0928\u0947 \u092a\u0930\u092e\u093e\u0924\u094d\u092e\u093e \u0915\u094b \u091a\u0941\u0928\u093e \u0939\u0948\u0902\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1116.48,
        "end": 1126.4,
        "text": "\u0907\u0938 \u0938\u0947 \u092a\u0939\u0932\u0947 \u0915\u093f \u0924\u0941\u092e \u092f\u0947 \u092a\u0942\u091b\u094b \u0915\u093f \u0924\u0941\u092e\u0939\u0947 \u0906\u091c\u093e\u0926\u0940 \u0915\u094d\u092f\u094b\u0902 \u0928\u0939\u0940\u0902 \u092e\u093f\u0932\u0924\u0940, \u0905\u092a\u0928\u0947 \u0906\u092a \u0938\u0947 \u092a\u0942\u091b\u094b \u0915\u093f \u0915\u094d\u092f\u093e \u0924\u0941\u092e \u0906\u091c\u093e\u0926\u0940 \u0915\u094b \u092e\u093f\u0932\u0947 \u0939\u094b\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1148.28,
        "end": 1168.4,
        "text": "\u0915\u093f\u0938\u0940 \u0915\u094b \u0928\u0939\u0940\u0902 \u092a\u093e\u0913\u0917\u0947 \u0926\u094b\u0937 \u0926\u0947\u0928\u0947 \u0915\u094b, \u0924\u0941\u092e \u0905\u092a\u0928\u0947 \u0906\u092a \u0915\u094b \u092d\u0940 \u0928\u0939\u0940\u0902 \u092a\u093e \u0938\u0915\u0924\u0947 \u0926\u094b\u0937 \u0926\u0947\u0928\u0947 \u0915\u094b, \u0924\u0941\u092e \u092f\u0947 \u092d\u0940 \u0928\u0939\u0940\u0902 \u0915\u0939 \u0938\u0915\u0924\u0947 \u0915\u093f \u092e\u0947\u0930\u0947 \u092a\u0941\u0930\u093e\u0928\u0947 \u0915\u0930\u092e\u094b \u0915\u093e \u092a\u0930\u093f\u0923\u093e\u092e \u0939\u0948, \u092e\u0947\u0930\u093e \u0906\u091c \u0915\u093e \u0926\u0941\u0915\u094d\u0916\u0964",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1169.96,
        "end": 1184.02,
        "text": "\u092a\u0930\u092e\u093e\u0924\u094d\u092e\u093e \u0915\u094b \u0924\u094b \u091a\u0941\u0921\u093c\u094b, \u0924\u0941\u092e \u0915\u0930\u092e\u092a\u0932 \u0915\u094b \u092d\u0940 \u0926\u094b\u0937 \u0928\u0939\u0940\u0902 \u0926\u0947 \u0938\u0915\u0924\u0947, \u0926\u094b\u0937\u0940 \u0939\u0948 \u0924\u094b \u0924\u0941\u092e\u094d\u0939\u093e\u0930\u0940 \u0907\u0938\u0940 \u092a\u0932 \u0915\u0940 \u092c\u0947\u0939\u0941\u0936\u0940, \u0914\u0930 \u092f\u0947 \u0924\u0941\u092e \u091a\u0941\u0928 \u0930\u0939\u0947 \u0939\u094b,",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1186.64,
        "end": 1199.02,
        "text": "\u0924\u0941\u092e \u0905\u092d\u0940 \u091c\u0917 \u091c\u093e\u0913, \u0924\u0941\u092e\u0939\u093e\u0930\u0947 \u0938\u093e\u0930\u0947 \u0915\u0930\u092e \u092a\u0932 \u0915\u091f \u091c\u093e\u090f\u0902\u0917\u0947, \u0924\u0941\u092e \u092c\u093f\u0932\u094d\u0915\u0941\u0932 \u092e\u0924 \u0915\u0939\u094b \u0915\u093f \u0915\u0930\u093e \u0939\u0948 \u0938\u094b \u092d\u0941\u0917\u0924 \u0930\u0939\u093e \u0939\u0942\u0902, \u092d\u0941\u0917\u0924\u0928\u0947 \u0915\u093e \u0905\u0925 \u0905\u092d\u0940 \u0939\u094b \u0938\u0915\u0924\u093e \u0939\u0948, \u0916\u0940\u0915 \u0905\u092d\u0940,",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1203.86,
        "end": 1214.4,
        "text": "\u0924\u0941\u092e \u092c\u093f\u0932\u094d\u0915\u0941\u0932 \u0928 \u0915\u0939\u0928\u093e \u0939\u0948 \u0915\u093f \u0939\u092e \u0915\u094d\u092f\u093e \u0915\u0930\u0947\u0902 \u092d\u0940, \u0907\u0936\u094d\u0935\u0930 \u0915\u0940 \u092e\u0930\u094d\u091c\u0940 \u0939\u0948, \u0928\u0939\u0940\u0902 \u0909\u0938\u0915\u0940 \u0910\u0938\u0940 \u0915\u094b\u0908 \u092e\u0930\u094d\u091c\u0940 \u0928\u0939\u0940\u0902 \u0939\u0948, \u0924\u0941\u092e\u0939\u093e\u0930\u0940 \u092e\u0930\u094d\u091c\u0940 \u0939\u0948,",
        "pause_after": true,
        "tonal_change": false
    },
    {
        "start": 1238.3799999999999,
        "end": 1239.78,
        "text": "\u0924\u0941\u092e\u0939\u093e\u0930\u0940 \u0928 \u0915\u0930\u0947\u0902 \u092d\u0940, \u092a\u0930 \u092a\u0930\u093e\u091c\u093c\u093e\u090f\u0902 \u092a\u0930 \u092a\u0930\u093e\u091c\u093c\u093e\u090f\u0902 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \u092a\u0930 \ufffd",
